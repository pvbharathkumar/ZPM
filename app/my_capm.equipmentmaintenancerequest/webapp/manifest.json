{
  "_version": "1.60.0",
  "sap.app": {
    "id": "mycapm.equipmentmaintenancerequest",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.25.0",
      "toolsId": "1825d495-9e13-41ac-adcf-6d3937095ca9"
    },
    "dataSources": {
      "mainService": {
        "uri": "/service/my_capm/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "mycapmequipmentmaintenancerequ-display": {
          "semanticObject": "mycapmequipmentmaintenancerequ",
          "action": "display",
          "title": "{{mycapmequipmentmaintenancerequ-display.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.13",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "mycapm.equipmentmaintenancerequest.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "MaintenanceNotificationsList",
          "target": "MaintenanceNotificationsList"
        },
        {
          "pattern": "MaintenanceNotifications({key}):?query:",
          "name": "MaintenanceNotificationsObjectPage",
          "target": "MaintenanceNotificationsObjectPage"
        },
        {
          "pattern": "MaintenanceNotifications({key})/costLines({key2}):?query:",
          "name": "CostEstimationLinesObjectPage",
          "target": "CostEstimationLinesObjectPage"
        },
        {
          "pattern": "Equipments({key}):?query:",
          "name": "EquipmentsObjectPage",
          "target": "EquipmentsObjectPage"
        }
      ],
      "targets": {
        "MaintenanceNotificationsList": {
          "type": "Component",
          "id": "MaintenanceNotificationsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "entitySet": "MaintenanceNotifications",
              "contextPath": "/MaintenanceNotifications",
              "variantManagement": "Page",
              "initialLoad": "Enabled",
              "navigation": {
                "MaintenanceNotifications": {
                  "detail": {
                    "route": "MaintenanceNotificationsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "MaintenanceNotificationsObjectPage": {
          "type": "Component",
          "id": "MaintenanceNotificationsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/MaintenanceNotifications",
              "navigation": {
                "costLines": {
                  "detail": {
                    "route": "CostEstimationLinesObjectPage"
                  }
                },
                "equipment": {
                  "detail": {
                    "route": "EquipmentsObjectPage"
                  }
                }
              }
            }
          }
        },
        "CostEstimationLinesObjectPage": {
          "type": "Component",
          "id": "CostEstimationLinesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/MaintenanceNotifications/costLines"
            }
          }
        },
        "EquipmentsObjectPage": {
          "type": "Component",
          "id": "EquipmentsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "entitySet": "Equipments",
              "contextPath": "/Equipments",
              "editableHeaderContent": false
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
